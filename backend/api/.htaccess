RewriteEngine On

<IfModule mod_headers.c>
    SetEnvIf Origin "^https://[\w.-]+\.vercel\.app$" CORS_ALLOW=$0
    SetEnvIf Origin "^http://localhost:5173$" CORS_ALLOW=$0
    Header always set Access-Control-Allow-Origin "%{CORS_ALLOW}e" env=CORS_ALLOW
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS" env=CORS_ALLOW
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRF-Token" env=CORS_ALLOW
    Header always set Access-Control-Allow-Credentials "true" env=CORS_ALLOW
</IfModule>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.php [L,QSA]
