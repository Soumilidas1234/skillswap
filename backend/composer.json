{
    "name": "skillswap-ai/backend",
    "description": "SkillSwap REST API Backend",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "classmap": [
            "config/",
            "controllers/",
            "helpers/",
            "middleware/",
            "models/",
            "routes/"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "platform-check": false
    }
}
